# LLM Serving (local-first)
BENCH_LLM_PROVIDER=ollama
BENCH_LLM_MODEL=qwen3:14b
BENCH_OLLAMA_HOST=http://localhost:11434

# Alternative: LM Studio
# BENCH_LLM_PROVIDER=lmstudio
# BENCH_LLM_MODEL=qwen3-14b
# BENCH_LMSTUDIO_HOST=http://localhost:1234

# Alternative: llama.cpp
# BENCH_LLM_PROVIDER=llamacpp
# BENCH_LLM_MODEL=qwen3-14b
# BENCH_LLAMACPP_HOST=http://localhost:8000

# Alternative: Cloud providers
# BENCH_LLM_PROVIDER=openai
# BENCH_LLM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...

# BENCH_LLM_PROVIDER=anthropic
# BENCH_LLM_MODEL=claude-sonnet-4-5-20250929
# ANTHROPIC_API_KEY=sk-ant-...

# Judge (can use different provider/model than benchmark)
BENCH_JUDGE_PROVIDER=ollama
BENCH_JUDGE_MODEL=qwen3:14b

# Benchmark parameters
BENCH_ITERATIONS=3
